rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Ogni utente può leggere e scrivere SOLO il proprio documento,
    // identificato dal suo uid di Firebase Auth.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Tutto il resto è bloccato di default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
